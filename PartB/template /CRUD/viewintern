<!DOCTYPE html>

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TESRECO - View Interns</title>

```
<style>

    *{
        margin:0;
        padding:0;
        box-sizing:border-box;
        font-family:'Segoe UI',sans-serif;
    }

    body{
        background:#f4f7fc;
    }

    /* NAVBAR */

    .navbar{
        background:#1e3a8a;
        color:white;
        padding:18px 40px;
        display:flex;
        justify-content:space-between;
        align-items:center;
    }

    .logo{
        font-size:28px;
        font-weight:bold;
    }

    .nav-links a{
        text-decoration:none;
        color:white;
        margin-left:20px;
        font-weight:500;
    }

    .nav-links a:hover{
        color:#ffd700;
    }

    /* HERO SECTION */

    .hero{
        text-align:center;
        padding:50px 20px;
    }

    .hero h1{
        color:#1e3a8a;
        margin-bottom:10px;
        font-size:38px;
    }

    .hero p{
        color:#555;
        font-size:18px;
    }

    /* DASHBOARD CARDS */

    .dashboard{
        width:90%;
        margin:auto;
        display:grid;
        grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
        gap:20px;
        margin-bottom:40px;
    }

    .card{
        background:white;
        padding:25px;
        border-radius:12px;
        text-align:center;
        box-shadow:0px 3px 10px rgba(0,0,0,0.1);
    }

    .card h2{
        color:#1e3a8a;
        margin-bottom:10px;
    }

    .card p{
        font-size:30px;
        font-weight:bold;
        color:#2563eb;
    }

    /* TABLE */

    .table-container{
        width:95%;
        margin:auto;
        background:white;
        padding:20px;
        border-radius:12px;
        box-shadow:0px 3px 10px rgba(0,0,0,0.1);
        overflow-x:auto;
        margin-bottom:40px;
    }

    table{
        width:100%;
        border-collapse:collapse;
    }

    th{
        background:#1e3a8a;
        color:white;
        padding:15px;
    }

    td{
        padding:15px;
        text-align:center;
        border-bottom:1px solid #ddd;
    }

    tr:hover{
        background:#f9f9f9;
    }

    /* BUTTONS */

    .btn{
        text-decoration:none;
        padding:8px 14px;
        border-radius:6px;
        color:white;
        font-size:14px;
        display:inline-block;
        margin:2px;
    }

    .edit{
        background:#10b981;
    }

    .edit:hover{
        background:#059669;
    }

    .delete{
        background:#ef4444;
    }

    .delete:hover{
        background:#dc2626;
    }

    /* EMPTY MESSAGE */

    .empty{
        text-align:center;
        padding:30px;
        color:#777;
        font-size:18px;
    }

    /* FOOTER */

    footer{
        background:#1e3a8a;
        color:white;
        text-align:center;
        padding:20px;
        margin-top:40px;
    }

</style>
```

</head>

<body>

```
<!-- NAVBAR -->

<div class="navbar">

    <div class="logo">
        TESRECO Portal
    </div>

    <div class="nav-links">
        <a href="/home">Home</a>
       

        <a href="/add">Add Intern</a>
        <a href="/view">View Interns</a>
    </div>

</div>

<!-- HERO -->

<div class="hero">

    <h1>Intern Management Dashboard</h1>

    <p>
        View, Edit and Manage All Registered Interns
    </p>

</div>

<!-- DASHBOARD -->

<div class="dashboard">

    <div class="card">

        <h2>Total Interns</h2>

        <p>{{ interns|length }}</p>

    </div>

    <div class="card">

        <h2>Active Domains</h2>

        <p>4+</p>

    </div>

    <div class="card">

        <h2>Training Programs</h2>

        <p>10+</p>

    </div>

</div>

<!-- TABLE -->

<div class="table-container">

    {% if interns %}

    <table>

        <tr>

            <th>ID</th>
            <th>Name</th>
            <th>Email</th>
            <th>Domain</th>
            <th>Duration</th>
            <th>Actions</th>

        </tr>

        {% for intern in interns %}

        <tr>

            <td>{{ intern[0] }}</td>
            <td>{{ intern[1] }}</td>
            <td>{{ intern[2] }}</td>
            <td>{{ intern[3] }}</td>
            <td>{{ intern[4] }}</td>

            <td>

                <a href="/edit/{{ intern[0] }}" class="btn edit">
                    Edit
                </a>

                <a href="/delete/{{ intern[0] }}"
                   class="btn delete"
                   onclick="return confirm('Delete this intern?')">
                    Delete
                </a>

            </td>

        </tr>

        {% endfor %}

    </table>

    {% else %}

    <div class="empty">

        No Interns Registered Yet

    </div>

    {% endif %}

</div>

<!-- FOOTER -->

<footer>

    <p>
        © 2026 TESRECO Technologies | Internship Management Portal
    </p>

</footer>
```

</body>
</html>
