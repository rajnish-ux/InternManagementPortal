            grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
            gap:20px;
        }

        .feature{
            background:white;
            padding:20px;
            border-radius:10px;
            box-shadow:0 0 8px rgba(0,0,0,0.1);
        }

        /* FOOTER */

